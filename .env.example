# ══════════════════════════════════════════════════════
#  AlphaCue Imports — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ══════════════════════════════════════════════════════

# ── Django Core ───────────────────────────────────────
# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-very-long-random-secret-key-here

# Set to False in production
DEBUG=False

# Your domain — comma separated
ALLOWED_HOSTS=alphacue.com,www.alphacue.com

# ── MySQL Database ────────────────────────────────────
# Get these from cPanel → MySQL Databases
DB_NAME=cpanel_username_dbname
DB_USER=cpanel_username_dbuser
DB_PASSWORD=your_database_password
DB_HOST=localhost
DB_PORT=3306

# ── File Paths (optional) ─────────────────────────────
# STATIC_ROOT=/home/cpaneluser/public_html/staticfiles
# MEDIA_ROOT=/home/cpaneluser/public_html/media

# ── Affiliate System ──────────────────────────────────
AFFILIATE_COOKIE_NAME=alphacue_ref
AFFILIATE_COOKIE_MAX_AGE=2592000
AFFILIATE_SESSION_KEY=affiliate_referral_code

# Generate: python -c "import secrets; print(secrets.token_hex(32))"
AFFILIATE_WEBHOOK_SECRET=generate-a-strong-random-string-here
